{
	"name": "chess_tree",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "next build",
		"check": "biome check .",
		"check:unsafe": "biome check --write --unsafe .",
		"check:write": "biome check --write .",
		"dev": "next dev --turbo",
		"preview": "next build && bun run start",
		"start": "cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && node .next/standalone/server.js",
		"db:generate": "bunx drizzle-kit generate",
		"db:migrate": "bun run src/server/db/migrate.ts",
		"db:seed": "bun run src/server/db/seed.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@auth/drizzle-adapter": "^1.11.2",
		"@base-ui/react": "^1.5.0",
		"@t3-oss/env-nextjs": "^0.12.0",
		"@tanstack/react-query": "^5.100.14",
		"@trpc/client": "^11.17.0",
		"@trpc/next": "^11.17.0",
		"@trpc/react-query": "^11.17.0",
		"@trpc/server": "^11.17.0",
		"@xyflow/react": "^12.11.0",
		"chess.js": "^1.4.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dagre": "^0.8.5",
		"drizzle-orm": "^0.45.2",
		"lucide-react": "^1.17.0",
		"next": "^15.2.3",
		"next-auth": "5.0.0-beta.25",
		"postgres": "^3.4.9",
		"react": "^19.0.0",
		"react-chessboard": "4.7.3",
		"react-dom": "^19.0.0",
		"react-resizable-panels": "^4.11.2",
		"shadcn": "^4.10.0",
		"superjson": "^2.2.6",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^3.24.2",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.5",
		"@playwright/test": "^1.60.0",
		"@tailwindcss/postcss": "^4.0.15",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/dagre": "^0.7.54",
		"@types/node": "^20.14.10",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"drizzle-kit": "^0.31.10",
		"jsdom": "^29.1.1",
		"postcss": "^8.5.3",
		"tailwindcss": "^4.0.15",
		"typescript": "^5.8.2",
		"vitest": "^4.1.8"
	},
	"ct3aMetadata": {
		"initVersion": "7.40.0"
	}
}
