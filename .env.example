# Required: Generate with `npx auth secret`
AUTH_SECRET=""

# Required: Google OAuth credentials from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Required: PostgreSQL connection string
# Docker Compose uses: postgresql://chess:chess@db:5432/chess_tree
DATABASE_URL="postgresql://postgres:password@localhost:5432/chess_tree"

# Optional: Set explicitly if behind a proxy
# AUTH_URL="http://localhost:3000"
